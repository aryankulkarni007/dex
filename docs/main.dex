struct Point {
    x: flt, y: flt

    @(self, other) distance -> flt {
      ((self.x - other.x)^2.0 + (self.y - other.y)^2.0)^0.5
    }
  }

@() main -> int {
  print("Hello World")

  # Declarations
  x: Point = Point(0.0, 1.0)
  y: Point = Point(1.0, 0.0)

  # using distance as a method
  distance = x:distance(y)
  print("{distance}")

  sqrt2 = 2.0^0.5
  print("{sqrt2}")


  correct = if distance == sqrt2 {
      true
    } else {
      false
    }

  print("{correct}")
}
